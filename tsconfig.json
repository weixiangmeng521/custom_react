{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/*", // 导入目录
    "**/*.ts",
    "packages/runtime",
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}